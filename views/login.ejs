<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Futuristic Tom Login Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Neon ambient pulse animation for UI glow */
        @keyframes cyanPulse {
            0%, 100% { border-color: rgba(6, 182, 212, 0.4); box-shadow: 0 0 15px rgba(6, 182, 212, 0.1); }
            50% { border-color: rgba(6, 182, 212, 0.8); box-shadow: 0 0 25px rgba(6, 182, 212, 0.3); }
        }
        .neon-border {
            animation: cyanPulse 4s infinite ease-in-out;
        }
    </style>
</head>
<body class="min-h-screen w-full bg-cover bg-center bg-no-repeat flex items-center justify-center font-sans px-4 sm:px-6 lg:px-8 relative overflow-x-hidden" 
      style="background-image: linear-gradient(to right, rgba(10, 15, 26, 0.85), rgba(10, 15, 26, 0.7)), url('https://images.unsplash.com/photo-1509198397868-475647b2a1e5?auto=format&fit=crop&w=1920&q=80');">

    <div class="absolute inset-0 bg-gradient-to-b from-cyan-950/20 via-transparent to-zinc-950/50 pointer-events-none"></div>

    <div class="w-full max-w-5xl flex flex-col md:flex-row items-center justify-center gap-12 lg:gap-20 relative z-10 py-8">
        
        <div class="w-full max-w-[320px] md:max-w-md flex justify-center md:justify-end animate-fade-in">
            <img class="w-full h-auto object-contain drop-shadow-[0_10px_30px_rgba(6,182,212,0.25)] filter contrast-105" 
                 src="https://cdna.artstation.com/p/assets/images/images/051/107/874/large/mikhail-sedov-tom-3.jpg?1656494747" 
                 alt="Cool Tom Cat"
                 style="max-height: 500px; border-radius: 24px;">
        </div>

        <div class="w-full max-w-md bg-slate-950/70 backdrop-blur-xl p-8 rounded-2xl border border-cyan-500/40 shadow-[0_0_40px_rgba(6,182,212,0.15)] neon-border transition-all duration-500">

            <div class="flex flex-col items-center mb-6">
                <div class="w-full h-12 flex items-center justify-center mb-4 opacity-80">
                    <svg class="w-48 h-full text-cyan-400" viewBox="0 0 100 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 15 Q12 15 25 15 T50 5 T75 25 T100 15" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M0 15 Q15 5 30 25 T60 15 T85 5 T100 15" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" fill="none" opacity="0.5"/>
                    </svg>
                </div>
                
                <h3 class="text-2xl font-bold tracking-widest text-cyan-400 uppercase text-center">
                    Login Your Account
                </h3>
                <p class="text-slate-400 text-xs mt-1 tracking-wide">SECURE BIOMETRIC & CREDENTIAL GATEWAY</p>
            </div>

            <form action="/login" method="post" class="flex flex-col gap-5">

                <div class="flex flex-col gap-1">
                    <label class="text-[10px] font-bold text-cyan-500 uppercase tracking-widest pl-1">User Identity</label>
                    <input
                        class="px-4 py-3 text-sm text-white outline-none rounded-xl bg-slate-900/80 border border-cyan-800/60 focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/20 transition-all duration-300 placeholder-slate-600 font-mono"
                        type="email"
                        placeholder="username@domain.com"
                        name="Email"
                        required>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-[10px] font-bold text-cyan-500 uppercase tracking-widest pl-1">Access Passkey</label>
                    <input
                        class="px-4 py-3 text-sm text-white outline-none rounded-xl bg-slate-900/80 border border-cyan-800/60 focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/20 transition-all duration-300 placeholder-slate-600 font-mono"
                        type="password"
                        placeholder="••••••••"
                        name="password"
                        required>
                </div>

                <div class="flex justify-end -mt-2">
                    <a href="#" class="text-xs text-cyan-400 hover:text-cyan-300 transition-colors tracking-wide">Reset Passkey?</a>
                </div>

                <button
                    type="submit"
                    class="mt-2 px-4 py-3 text-base font-bold text-white uppercase tracking-wider rounded-xl bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-cyan-500/20 cursor-pointer text-center relative overflow-hidden group border border-cyan-400/30">
                    <span class="relative z-10">Sign In</span>
                    <div class="absolute inset-0 w-full h-1/2 bg-white/10 transform -translate-y-full group-hover:animate-scan"></div>
                </button>

            </form>

            <p class="text-center text-xs text-slate-500 mt-6 tracking-wide">
                New Operator? <a href="#" class="text-cyan-400 hover:underline">Register Node</a>
            </p>

        </div>

    </div>

<script>
    tailwind.config = {
        theme: {
            extend: {
                animation: {
                    scan: 'scan 1s ease-out infinite',
                },
                keyframes: {
                    scan: {
                        '100%': { transform: 'translateY(200%)' },
                    }
                }
            }
        }
    }
</script>

</body>
</html>