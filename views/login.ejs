<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

<div class="w-full min-h-screen bg-zinc-900 text-white flex items-center justify-center">

    <div class="w-full max-w-md">

        <h3 class="text-4xl mb-8 text-center">
            Login Your Account
        </h3>

        <form action="/login" method="post" class="flex flex-col gap-4">

            <input
                class="px-4 py-3 text-lg outline-none rounded-md bg-transparent border-2 border-yellow-800"
                type="email"
                placeholder=" Your Email"
                name="Email">

            <input
                class="px-4 py-3 text-lg outline-none rounded-md bg-transparent border-2 border-yellow-800"
                type="password"
                placeholder="Password"
                name="password">

            <input
                class="px-4 py-3 text-lg outline-none rounded-md bg-blue-500 border-2 border-blue-800 cursor-pointer"
                type="submit"
                value="Login">

        </form>

    </div>

</div>

</body>
</html>
