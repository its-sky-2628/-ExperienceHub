<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <a class="bg-red-500 rounded-md px-2 py-1 inline-block mb-5 text-white" href="/logout">
            Logout
        </a>

        <h5 class="mb-5 text-2xl">Edit Your Post</h5>

        <form action="/update/<%= post._id %>" method="post">

            <textarea
                placeholder="Write what's on your mind"
                class="p-5 w-full resize-none bg-transparent border-2 border-zinc-800 rounded-md"
                name="content"
                id="content"
                rows="10"><%= post.content %></textarea>

            <input
                class="px-3 py-2 bg-yellow-500 text-black block rounded-md mt-2"
                type="submit"
                value="Edit Post">

        </form>

    </div>

</body>
</html>