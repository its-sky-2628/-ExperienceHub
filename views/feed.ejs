<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExperienceHub Feed</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen">

    <div class="max-w-7xl mx-auto p-6">

        <h1 class="text-5xl font-bold text-center mb-10 bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">
            Community Feed ✨
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

            <% posts.forEach(function(post){ %>

            <div class="bg-zinc-900/90 border border-zinc-800 rounded-3xl p-6 shadow-xl hover:border-blue-500/40 hover:shadow-blue-500/10 transition duration-300">

                <!-- User Header -->
                <div class="flex items-center justify-between mb-4">

                    <div>
                        <h3 class="text-blue-400 text-xl font-bold">
                            @<%= post.user.username %>
                        </h3>

                        <p class="text-zinc-500 text-sm">
                            Shared an experience
                        </p>
                    </div>

                    <% if(post.user._id.toString() !== currentUser._id.toString()) { %>

                        <% if(currentUser.following.map(id => id.toString()).includes(post.user._id.toString())) { %>

                            <a
                                href="/follow/<%= post.user._id %>"
                                class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-xl text-sm font-semibold transition">

                                Unfollow

                            </a>

                        <% } else { %>

                            <a
                                href="/follow/<%= post.user._id %>"
                                class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-xl text-sm font-semibold transition">

                                Follow

                            </a>

                        <% } %>

                    <% } %>

                </div>

                <!-- Premium Post Content -->
                <div class="border-l-4 border-blue-500 pl-5 mb-6">

                    <p class="text-zinc-100 text-xl leading-10 whitespace-pre-wrap break-words tracking-wide">
                        <%= post.content %>
                    </p>

                </div>

                <!-- Like Section -->
                <div class="mb-4">

                    <a
                        href="/like/<%= post._id %>"
                        class="text-red-400 hover:text-red-300 text-lg font-medium transition">

                        ❤️ <%= post.likes.length %> Likes

                    </a>

                </div>

                <!-- Comment Form -->
                <form action="/comment/<%= post._id %>" method="post" class="mb-4">

                    <input
                        type="text"
                        name="comment"
                        placeholder="Write a comment..."
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-3 text-white focus:outline-none focus:border-blue-500">

                    <button
                        type="submit"
                        class="mt-3 bg-green-600 hover:bg-green-700 px-5 py-3 rounded-xl font-medium transition">

                        Comment

                    </button>

                </form>

                <!-- Comments -->
                <% if(post.comments && post.comments.length > 0){ %>

                <div class="border-t border-zinc-800 pt-4">

                    <h4 class="text-zinc-400 text-sm mb-3">
                        Comments
                    </h4>

                    <% post.comments.forEach(function(comment){ %>

                    <div class="bg-zinc-950 rounded-xl p-3 mb-3 border border-zinc-800">

                        <p class="text-zinc-300 text-sm leading-7">
                            💬 <%= comment.text %>
                        </p>

                    </div>

                    <% }) %>

                </div>

                <% } %>

            </div>

            <% }) %>

        </div>

    </div>

</body>
</html>