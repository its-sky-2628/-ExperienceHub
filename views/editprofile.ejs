<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - ExperienceHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes floatEffect {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(1deg); }
        }
        .hero-float {
            animation: floatEffect 4s infinite ease-in-out;
        }
    </style>
</head>

<!-- Background color specified: bg-zinc-950 -->
<body class="bg-zinc-950 text-white min-h-screen selection:bg-blue-600 selection:text-white overflow-x-hidden relative">

    <!-- ✅ 8. Background Glow Stack (Subtle premium effect) -->
    <div class="fixed top-0 left-0 w-96 h-96 bg-blue-600/10 blur-[140px] rounded-full pointer-events-none"></div>
    <div class="fixed bottom-0 right-0 w-96 h-96 bg-purple-600/10 blur-[140px] rounded-full pointer-events-none"></div>

    <div class="max-w-6xl mx-auto py-12 px-6 relative z-10">

        <!-- Header Back Navigation Link -->
        <div class="flex justify-between items-center mb-10 pb-6 border-b border-zinc-800/60">
            <a href="/profile" class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-all duration-300 font-medium">
                <span class="inline-block transform group-hover:-translate-x-1 transition-transform">⬅️</span> Back to Profile
            </a>
            <span class="text-xs bg-zinc-900 border border-zinc-800 text-zinc-400 font-mono px-3 py-1 rounded-full uppercase tracking-wider">
                Account Settings
            </span>
        </div>

        <!-- ✅ 1. Heading Component with Accent Gradient styling applied -->
        <h1 class="text-5xl font-extrabold bg-gradient-to-r from-blue-400 via-cyan-400 to-purple-500 bg-clip-text text-transparent text-center mb-16 tracking-tight">
            ✏️ Edit Profile
        </h1>

        <div class="grid lg:grid-cols-12 gap-10 items-center">

            <!-- ✅ 2. Left Preview Card Panel Context -->
            <div class="lg:col-span-5 bg-gradient-to-br from-zinc-900 to-zinc-800 border border-zinc-800 rounded-3xl p-8 flex flex-col items-center text-center relative group hover:scale-[1.02] transition-all duration-300 shadow-xl">
                
                <!-- Floating Spider-Man Graphic Aspect Asset Anchor -->
                <div class="absolute -top-20 left-1/2 transform -translate-x-1/2 w-28 h-28 hero-float pointer-events-none drop-shadow-[0_8px_12px_rgba(59,130,246,0.3)]">
                    <img src="https://media.giphy.com/media/1qjCXhkDsxbHs4IxV8/giphy.gif" alt="Spidey Hero" class="w-full h-full object-contain">
                </div>

                <!-- Profile Pic Frame Area Wrapper -->
                <div class="mt-10 mb-6 relative inline-block">
                    <!-- ✅ 3. Profile Image Adaptive Element with Blue Glow Shadow Matrix -->
                    <% if(user.profilePic && user.profilePic.trim() !== ""){ %>
                        <img 
                            src="<%= user.profilePic %>" 
                            class="w-32 h-32 rounded-full object-cover border-4 border-blue-500 shadow-[0_0_35px_rgba(59,130,246,0.4)]">
                    <% } else { %>
                        <div class="w-32 h-32 rounded-full bg-gradient-to-tr from-blue-600 to-purple-600 flex justify-center items-center text-5xl font-black border-4 border-blue-500 shadow-[0_0_35px_rgba(59,130,246,0.4)]">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <div class="absolute bottom-1 right-1 bg-green-500 w-4 h-4 rounded-full border-2 border-zinc-900 animate-pulse"></div>
                </div>

                <!-- Text metadata component structures -->
                <h2 class="text-2xl font-bold tracking-tight text-white group-hover:text-blue-400 transition-colors">
                    <%= user.name %>
                </h2>
                <p class="text-purple-400 font-mono text-sm mt-1">@<%= user.username %></p>
                
                <div class="w-full h-[1px] bg-zinc-800 my-5"></div>
                
                <p class="text-zinc-400 text-sm leading-relaxed italic px-4 py-3 bg-zinc-950/40 rounded-xl border border-zinc-900 w-full min-h-[44px]">
                    "<%= (user.bio && user.bio.trim() !== '') ? user.bio : 'No bio available yet.' %>"
                </p>
            </div>

            <!-- ✅ 4. Right Form Control Interface Section Box -->
            <div class="lg:col-span-7 bg-gradient-to-br from-zinc-900 to-zinc-950 border border-zinc-800 rounded-3xl p-8 shadow-xl">
                
                <form action="/edit-profile" method="post" class="space-y-6">

                    <!-- Field Input Component Instance Name -->
                    <div>
                        <!-- ✅ 7. Label Elements Dynamic Styling Interface -->
                        <label class="block text-zinc-300 font-semibold mb-2">
                            <i class="fa-solid fa-user text-blue-400 mr-2 text-sm"></i>Full Name
                        </label>
                        <!-- ✅ 5. Adaptive Responsive Form Text Controls Configured with Blue Focus Glow -->
                        <input
                            type="text"
                            name="name"
                            value="<%= user.name %>"
                            required
                            class="w-full bg-zinc-950 border border-zinc-700 rounded-xl p-4 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition-all">
                    </div>

                    <!-- Field Input Component Instance Handle -->
                    <div>
                        <label class="block text-zinc-300 font-semibold mb-2">
                            <i class="fa-solid fa-at text-purple-400 mr-2 text-sm"></i>Username
                        </label>
                        <input
                            type="text"
                            name="username"
                            value="<%= user.username %>"
                            required
                            class="w-full bg-zinc-950 border border-zinc-700 rounded-xl p-4 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition-all font-mono">
                    </div>

                    <!-- Field Input Component Instance Biography Description text area container -->
                    <div>
                        <label class="block text-zinc-300 font-semibold mb-2">
                            <i class="fa-solid fa-pen-nib text-cyan-400 mr-2 text-sm"></i>Bio Description
                        </label>
                        <textarea
                            name="bio"
                            rows="4"
                            placeholder="Share your technical expertise or thoughts..."
                            class="w-full bg-zinc-950 border border-zinc-700 rounded-xl p-4 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition-all resize-none leading-relaxed"><%= user.bio %></textarea>
                    </div>

                    <!-- ✅ 6. Premium Responsive Animated Gradient Submission Command Control Button UI Layer -->
                    <button class="w-full py-4 rounded-xl bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 font-bold text-lg transition-all hover:scale-[1.02] shadow-lg flex items-center justify-center gap-2">
                        💾 Save Changes
                    </button>

                </form>

            </div>

        </div>

    </div>

</body>
</html>