x<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - ExperienceHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Superhero / Gaming Glow Mode Core Elements */
        @keyframes floatEffect {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-12px) rotate(2deg); }
        }
        @keyframes subtlePulse {
            0%, 100% { box-shadow: 0 0 15px rgba(59, 130, 246, 0.4), inset 0 0 15px rgba(59, 130, 246, 0.2); }
            50% { box-shadow: 0 0 30px rgba(239, 68, 68, 0.6), inset 0 0 25px rgba(239, 68, 68, 0.3); }
        }
        .hero-float {
            animation: floatEffect 4s infinite ease-in-out;
        }
        .card-pulse {
            animation: subtlePulse 4s infinite ease-in-out;
        }
        .custom-focus:focus {
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
            border-color: #3b82f6;
            background-color: rgba(9, 9, 11, 0.9);
            transform: scale(1.01);
        }
    </style>
</head>

<body class="bg-zinc-950 text-white min-h-screen selection:bg-red-600 selection:text-white overflow-x-hidden">

<div class="max-w-6xl mx-auto py-12 px-6 relative">

    <!-- Ambient Neon Lights -->
    <div class="absolute top-1/4 -left-20 w-72 h-72 bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 -right-20 w-72 h-72 bg-red-600/10 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- NAVIGATION HEADER -->
    <div class="flex justify-between items-center mb-10 pb-6 border-b border-zinc-900 relative z-10">
        <a href="/profile" class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-all duration-300 font-medium">
            <span class="inline-block transform group-hover:-translate-x-2 transition-transform duration-300">⚡</span> Back to Feed / Profile
        </a>
        <span class="text-xs bg-red-500/10 text-red-400 font-mono px-3 py-1 rounded-full border border-red-500/20 tracking-wider animate-pulse">
            <i class="fa-solid Nav-Icon fa-circle-dot mr-1 text-[10px]"></i> Live Editing Setup
        </span>
    </div>

    <!-- MAIN GRID SECTION -->
    <div class="grid lg:grid-cols-12 gap-10 items-center relative z-10">

        <!-- LEFT DISPLAY SIDE (The Ultimate Cartoon Preview Section) -->
        <div class="lg:col-span-5 flex flex-col items-center">
            
            <!-- Character Layer Box -->
            <div class="w-full max-w-sm bg-gradient-to-b from-zinc-900 to-zinc-950 rounded-3xl border border-zinc-800/80 p-6 text-center card-pulse relative group">
                
                <!-- CARTOON GIF / AVATAR POPPER (Spider-Man Interactive Element) -->
                <div class="absolute -top-24 left-1/2 transform -translate-x-1/2 w-32 h-32 hero-float pointer-events-none drop-shadow-[0_10px_15px_rgba(239,68,68,0.5)]">
                    <img src="https://media.giphy.com/media/1qjCXhkDsxbHs4IxV8/giphy.gif" alt="Spidey Cartoon Character" class="w-full h-full object-contain">
                </div>

                <!-- Custom Avatar Frame Container -->
                <div class="mt-12 mb-6 relative inline-block">
                    <% if(user.profilePic && user.profilePic.trim() !== ""){ %>
                        <img src="<%= user.profilePic %>" class="w-28 h-28 rounded-2xl object-cover mx-auto border-2 border-blue-500 ring-4 ring-zinc-900 shadow-2xl transition-transform duration-500 group-hover:scale-105">
                    <% } else { %>
                        <div class="w-28 h-28 rounded-2xl bg-gradient-to-tr from-red-600 via-blue-600 to-indigo-700 mx-auto flex items-center justify-center text-4xl font-black border-2 border-white/20 ring-4 ring-zinc-900 shadow-2xl">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <div class="absolute -bottom-2 -right-2 bg-green-500 w-5 h-5 rounded-full border-4 border-zinc-900"></div>
                </div>

                <!-- Bio / Handle Data Card Stack -->
                <h2 class="text-2xl font-black tracking-tight text-zinc-100 group-hover:text-blue-400 transition-colors duration-300">
                    <%= user.name %>
                </h2>
                <p class="text-red-400 font-mono text-sm mt-1 font-semibold">@<%= user.username %></p>
                
                <div class="h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent my-4"></div>
                
                <p class="text-zinc-400 text-sm leading-relaxed italic px-2 bg-zinc-950/40 py-3 rounded-xl border border-zinc-900">
                    "<%= (user.bio && user.bio.trim() !== '') ? user.bio : 'Web-slinging through coding platforms! Update your bio now.' %>"
                </p>
            </div>
            
        </div>

        <!-- RIGHT DISPLAY SIDE (Action Forms Layout Elements) -->
        <div class="lg:col-span-7 bg-zinc-900/40 backdrop-blur-xl rounded-3xl border border-zinc-800 p-8 relative overflow-hidden">
            
            <form action="/edit-profile" method="post" class="space-y-6">

                <!-- Input Item Field: Full Name -->
                <div>
                    <label class="block mb-2 text-sm font-bold text-zinc-400 flex items-center gap-2">
                        <i class="fa-solid fa-signature text-blue-500"></i> Full Identity Name
                    </label>
                    <input
                        type="text"
                        name="name"
                        value="<%= user.name %>"
                        required
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 text-white focus:outline-none transition-all duration-300 custom-focus">
                </div>

                <!-- Input Item Field: Username -->
                <div>
                    <label class="block mb-2 text-sm font-bold text-zinc-400 flex items-center gap-2">
                        <i class="fa-solid fa-at text-red-500"></i> Secret Handle / Username
                    </label>
                    <input
                        type="text"
                        name="username"
                        value="<%= user.username %>"
                        required
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 text-white focus:outline-none transition-all duration-300 custom-focus font-mono">
                </div>

                <!-- Input Item Field: Bio Description -->
                <div>
                    <label class="block mb-2 text-sm font-bold text-zinc-400 flex items-center gap-2">
                        <i class="fa-solid fa-scroll text-green-500"></i> Superhero Bio Logs
                    </label>
                    <textarea
                        name="bio"
                        rows="4"
                        placeholder="Write down your legendary developer story..."
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 text-white focus:outline-none transition-all duration-300 custom-focus resize-none leading-relaxed"><%= user.bio %></textarea>
                </div>

                <!-- Ultimate Save Button with Internal Particle Spark Feel -->
                <button type="submit" class="w-full bg-gradient-to-r from-red-600 via-purple-600 to-blue-600 hover:from-red-500 hover:to-blue-500 text-white py-4 rounded-xl text-lg font-black transition-all duration-300 transform hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(59,130,246,0.3)] active:scale-[0.98] flex items-center justify-center gap-2">
                    <i class="fa-solid fa-bolt animate-bounce"></i> SAVE PROFILE CHANGES
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>