<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - ExperienceHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Smooth Custom Glowing Animations */
        @keyframes pulse-glow {
            0%, 100% { transform: scale(1); box-shadow: 0 0 15px rgba(59, 130, 246, 0.4); }
            50% { transform: scale(1.03); box-shadow: 0 0 25px rgba(59, 130, 246, 0.7); }
        }
        .animate-avatar {
            animation: pulse-glow 3s infinite ease-in-out;
        }
        .focus-glow:focus {
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.3);
            transform: translateY(-2px);
        }
    </style>
</head>

<body class="bg-zinc-950 text-white min-h-screen selection:bg-blue-600 selection:text-white">

<div class="max-w-6xl mx-auto py-12 px-6">

    <!-- TOP HEADER NAVIGATION -->
    <div class="flex justify-between items-center mb-10 pb-6 border-b border-zinc-900">
        <a href="/profile" class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-all duration-300">
            <span class="transform group-hover:-translate-x-1 transition-transform">⬅️</span> Back to Profile
        </a>
        <span class="text-xs text-zinc-500 uppercase tracking-widest bg-zinc-900/50 px-3 py-1 rounded-full border border-zinc-800">Settings</span>
    </div>

    <h1 class="text-4xl md:text-5xl font-extrabold text-center mb-12 tracking-tight">
        ✏️ <span class="bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400 bg-clip-text text-transparent">Edit Profile</span>
    </h1>

    <div class="grid lg:grid-cols-12 gap-10">

        <!-- LEFT CARD (Interactive Preview) -->
        <div class="lg:col-span-5 bg-zinc-900/40 backdrop-blur-md rounded-3xl border border-zinc-800/80 p-8 flex flex-col justify-center items-center relative overflow-hidden group hover:border-zinc-700/50 transition-all duration-500">
            
            <!-- Subtle background ambient light -->
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-blue-500/10 rounded-full blur-3xl group-hover:bg-blue-500/20 transition-all duration-500"></div>
            
            <div class="flex flex-col items-center relative z-10">

                <div class="relative">
                    <% if(user.profilePic && user.profilePic.trim() !== ""){ %>
                        <img
                            src="<%= user.profilePic %>"
                            class="w-36 h-36 md:w-40 md:h-40 rounded-full object-cover border-4 border-blue-500/80 shadow-2xl animate-avatar">
                    <% } else { %>
                        <div class="w-36 h-36 md:w-40 md:h-40 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-700 flex justify-center items-center text-6xl font-black shadow-2xl animate-avatar border-4 border-blue-500/40">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="absolute bottom-2 right-2 bg-blue-600 text-xs px-2 py-1 rounded-md font-semibold border border-zinc-950">LIVE</span>
                </div>

                <h2 class="text-3xl font-bold mt-8 tracking-tight group-hover:text-blue-400 transition-colors duration-300">
                    <%= user.name %>
                </h2>

                <p class="text-zinc-500 font-mono text-sm mt-1">
                    @<%= user.username %>
                </p>

                <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent my-6"></div>

                <p class="text-center text-zinc-400 text-sm leading-relaxed max-w-sm italic">
                    "<%= (user.bio && user.bio.trim() !== '') ? user.bio : 'Write something incredible about yourself in the bio form...' %>"
                </p>

            </div>
        </div>

        <!-- RIGHT CARD (Animated Form Configuration) -->
        <div class="lg:col-span-7 bg-zinc-900/40 backdrop-blur-md rounded-3xl border border-zinc-800/80 p-8 hover:border-zinc-700/50 transition-all duration-500 relative">
            
            <form action="/edit-profile" method="post" class="space-y-6">

                <!-- Input Field: Name -->
                <div class="group/field">
                    <label class="block mb-2 text-sm font-semibold text-zinc-400 group-focus-within/field:text-blue-400 transition-colors duration-300">
                        Full Name
                    </label>
                    <input
                        type="text"
                        name="name"
                        value="<%= user.name %>"
                        required
                        class="w-full bg-zinc-950/80 border border-zinc-800 hover:border-zinc-700 focus:border-blue-500 rounded-2xl p-4 text-white focus:outline-none transition-all duration-300 focus-glow">
                </div>

                <!-- Input Field: Username -->
                <div class="group/field">
                    <label class="block mb-2 text-sm font-semibold text-zinc-400 group-focus-within/field:text-blue-400 transition-colors duration-300">
                        Username
                    </label>
                    <div class="relative">
                        <span class="absolute left-4 top-4 text-zinc-600 font-mono">@</span>
                        <input
                            type="text"
                            name="username"
                            value="<%= user.username %>"
                            required
                            class="w-full bg-zinc-950/80 border border-zinc-800 hover:border-zinc-700 focus:border-blue-500 rounded-2xl p-4 pl-9 text-white focus:outline-none transition-all duration-300 focus-glow font-mono">
                    </div>
                </div>

                <!-- Input Field: Bio -->
                <div class="group/field">
                    <label class="block mb-2 text-sm font-semibold text-zinc-400 group-focus-within/field:text-blue-400 transition-colors duration-300">
                        Biography
                    </label>
                    <textarea
                        name="bio"
                        rows="4"
                        placeholder="Tell the world your story, experiences, or tech stack..."
                        class="w-full bg-zinc-950/80 border border-zinc-800 hover:border-zinc-700 focus:border-blue-500 rounded-2xl p-4 text-white focus:outline-none transition-all duration-300 focus-glow resize-none leading-relaxed"><%= user.bio %></textarea>
                </div>

                <!-- Animated Interactive Save Button -->
                <button class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 py-4 rounded-2xl text-lg font-bold transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-500/25 active:scale-95 flex items-center justify-center gap-2">
                    <span>💾</span> Save Changes
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>