<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">

<title>Edit Profile</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-zinc-950 text-white">

<div class="max-w-xl mx-auto mt-16 bg-zinc-900 rounded-2xl p-8">

<h1 class="text-3xl font-bold mb-8">

Edit Profile

</h1>

<form action="/edit-profile" method="post">

<label>Name</label>

<input
type="text"
name="name"
value="<%= user.name %>"
class="w-full bg-zinc-950 border border-zinc-700 rounded-xl p-3 mt-2 mb-5">

<label>Username</label>

<input
type="text"
name="username"
value="<%= user.username %>"
class="w-full bg-zinc-950 border border-zinc-700 rounded-xl p-3 mt-2 mb-5">

<label>Bio</label>

<textarea
name="bio"
class="w-full bg-zinc-950 border border-zinc-700 rounded-xl p-3 mt-2 mb-6 h-28"><%= user.bio || "" %></textarea>

<button
class="w-full bg-blue-600 hover:bg-blue-700 py-3 rounded-xl font-semibold">

Save Changes

</button>

</form>

</div>

</body>

</html>