<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dynamic Password Recovery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* Custom Styles for Advanced Effects */

        body {
            perspective: 1000px; /* Essential for 3D rotation */
            overflow: hidden; /* Keep background particles contained */
        }

        /* 1. Futuristic Background Mesh (Connecting Dots) */
        #bg-canvas {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -2;
            opacity: 0.5;
        }

        /* 2. Main 3D Tilt Card Container */
        .tilt-card {
            transform-style: preserve-3d;
            transition: transform 0.1s ease-out; /* Smooth tilt */
        }

        /* 3. Glassmorphism Base with Holographic Scan Line */
        .glass-base {
            background: rgba(10, 10, 15, 0.7);
            backdrop-filter: blur(15px) saturate(180%);
            border: 1px solid rgba(100, 150, 255, 0.15);
            position: relative;
            overflow: hidden;
        }

        /* The Scan Line animation */
        .glass-base::before {
            content: '';
            position: absolute;
            top: -100%; left: 0; width: 100%; height: 100%;
            background: linear-gradient(
                to bottom,
                transparent,
                rgba(59, 130, 246, 0.05) 40%,
                rgba(59, 130, 246, 0.2) 50%,
                rgba(59, 130, 246, 0.05) 60%,
                transparent
            );
            animation: scanline 8s linear infinite;
            z-index: 0;
            pointer-events: none;
        }

        @keyframes scanline {
            to { top: 100%; }
        }

        /* 4. Content should always be above the scan line */
        .form-content {
            position: relative;
            z-index: 1;
        }

        /* 5. Neon Particle Container */
        .particle-emitter {
            position: absolute;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        /* 6. Dynamic Input: Border Beam Effect */
        .input-wrapper::after {
            content: '';
            position: absolute;
            inset: -2px;
            background: linear-gradient(90deg, #3b82f6, #818cf8, #3b82f6);
            background-size: 200% 100%;
            border-radius: 12px;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .input-wrapper:focus-within::after {
            opacity: 1;
            animation: border-beam 2s linear infinite;
        }

        @keyframes border-beam {
            0% { background-position: 0% 0; }
            100% { background-position: 200% 0; }
        }

        /* 7. Pulsing Icon in the background */
        .bg-pulse-icon {
            position: absolute;
            font-size: 20rem;
            color: rgba(59, 130, 246, 0.03);
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            z-index: -1;
            animation: icon-pulse 10s ease-in-out infinite;
        }

        @keyframes icon-pulse {
            0%, 100% { opacity: 0.03; transform: translate(-50%, -50%) scale(1); }
            50% { opacity: 0.06; transform: translate(-50%, -50%) scale(1.05); }
        }

    </style>
</head>
<body class="bg-[#050509] text-white flex items-center justify-center min-h-screen p-4 antialiased selection:bg-blue-500/30">

    <canvas id="bg-canvas"></canvas>

    <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-[-1]">
        <div class="absolute -top-40 left-1/4 w-96 h-96 bg-blue-900/30 rounded-full blur-[160px]"></div>
        <div class="absolute -bottom-40 right-1/4 w-96 h-96 bg-indigo-900/30 rounded-full blur-[160px]"></div>
    </div>

    <div class="tilt-card relative w-full max-w-md group" id="card">
        
        <div class="particle-emitter" id="particle-emitter"></div>

        <i class="fa-solid fa-shield-alt bg-pulse-icon"></i>

        <form class="glass-base p-10 rounded-3xl shadow-3xl" onsubmit="event.preventDefault(); return false;">
            
            <div class="form-content">
                <div class="flex flex-col items-center mb-10">
                    <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-400 mb-5 border border-blue-500/20 shadow-inner group-hover:scale-110 group-hover:rotate-6 transition-transform duration-300">
                        <i class="fa-solid fa-user-lock text-2xl animate-pulse"></i>
                    </div>
                    <h2 class="text-white text-3xl font-extrabold tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-blue-100 to-white">
                        Access Recovery
                    </h2>
                    <p class="text-zinc-400 text-sm mt-2 text-center max-w-xs">
                        Initiate secure identity validation to reset your access credentials.
                    </p>
                </div>

                <div class="mb-8 relative input-wrapper">
                    <label class="text-xs font-semibold text-zinc-400 block mb-2.5 uppercase tracking-wider transition-colors">
                        Authorized Email Address
                    </label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-zinc-500 pointer-events-none group-focus-within:text-blue-400 transition-colors">
                            <i class="fa-regular fa-envelope"></i>
                        </span>
                        <input
                            type="email"
                            required
                            placeholder="username@securemail.io"
                            class="w-full pl-11 pr-5 py-4 rounded-xl bg-zinc-900/50 border border-zinc-700/60 text-white placeholder-zinc-600 outline-none transition-all duration-300 group-hover:border-zinc-600 focus:bg-[#080810]">
                    </div>
                </div>

                <button
                    type="submit"
                    class="w-full bg-transparent border-2 border-blue-600/60 hover:border-blue-400 text-blue-100 font-bold py-4 rounded-xl transition-all duration-300 shadow-lg relative overflow-hidden group/btn">
                    
                    <div class="absolute inset-0 bg-gradient-to-r from-blue-800 to-indigo-900 opacity-20 group-hover/btn:opacity-100 transition-opacity duration-500"></div>

                    <div class="relative flex items-center justify-center gap-2.5">
                        <span class="tracking-tight">Send Secure Link</span>
                        <i class="fa-solid fa-satellite-dish text-sm animate-[pulse_1.5s_ease-in-out_infinite]"></i>
                    </div>

                    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1/2 h-1 bg-blue-400 blur-md opacity-70 group-hover/btn:w-full transition-all duration-500"></div>
                </button>

                <div class="mt-8 text-center">
                    <a href="#" class="text-sm text-zinc-500 hover:text-white transition-colors duration-200 inline-flex items-center gap-2 group/back">
                        <i class="fa-solid fa-angles-left text-xs transition-transform duration-300 group-hover/back:-translate-x-1"></i>
                        Return to Secure Login Portal
                    </a>
                </div>
            </div>

        </form>
    </div>

    <script>
        // 1. Particle Background Logic (The interactive dots)
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        let mouse = { x: null, y: null, radius: 150 };

        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.radius = Math.random() * 1.5 + 0.5;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(100, 150, 255, 0.2)';
                ctx.fill();
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x > canvas.width) this.x = 0; if (this.x < 0) this.x = canvas.width;
                if (this.y > canvas.height) this.y = 0; if (this.y < 0) this.y = canvas.height;
            }
        }

        function initParticles() {
            for (let i = 0; i < 80; i++) particles.push(new Particle());
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            
            // Connect particles
            for(let i=0; i<particles.length; i++) {
                for(let j=i; j<particles.length; j++) {
                    let dx = particles[i].x - particles[j].x;
                    let dy = particles[i].y - particles[j].y;
                    let dist = Math.sqrt(dx*dx + dy*dy);
                    if(dist < 100) {
                        ctx.beginPath();
                        ctx.lineWidth = 0.2;
                        ctx.strokeStyle = `rgba(100, 150, 255, ${0.1 * (1 - dist/100)})`;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animateParticles);
        }

        initParticles();
        animateParticles();

        // Resize Canvas
        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            particles = []; initParticles();
        });

        // 2. 3D Tilt Logic
        const card = document.getElementById('card');
        document.body.addEventListener('mousemove', e => {
            let xAxis = (window.innerWidth / 2 - e.clientX) / 25;
            let yAxis = (window.innerHeight / 2 - e.clientY) / 25;
            card.style.transform = `rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
        });

        // Reset Tilt
        document.body.addEventListener('mouseleave', () => {
            card.style.transform = `rotateY(0deg) rotateX(0deg)`;
        });

        // 3. Simple Neon Floating Particles (from the emitter)
        const emitter = document.getElementById('particle-emitter');
        function createNeonParticle() {
            const p = document.createElement('div');
            p.classList.add('absolute', 'w-1', 'h-1', 'bg-blue-400/80', 'rounded-full', 'blur-sm');
            p.style.bottom = '10%'; p.style.left = Math.random() * 100 + '%';
            emitter.appendChild(p);
            
            p.animate([
                { transform: 'translateY(0) scale(1)', opacity: 0.8 },
                { transform: `translateY(-300px) translateX(${(Math.random()-0.5)*100}px) scale(0)`, opacity: 0 }
            ], { duration: 4000 + Math.random()*2000, easing: 'ease-out' });

            setTimeout(() => p.remove(), 6000);
        }
        setInterval(createNeonParticle, 1500); // Create every 1.5s

    </script>

</body>
</html>