<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gradient-to-tr from-zinc-950 via-slate-900 to-zinc-950 flex items-center justify-center min-h-screen p-4 antialiased selection:bg-blue-500/30 selection:text-blue-200">

    <div class="relative w-full max-w-md transform transition-all duration-300 hover:scale-[1.01]">
        
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>

        <form class="bg-zinc-900/80 backdrop-blur-xl border border-zinc-800/80 p-8 rounded-2xl shadow-2xl relative overflow-hidden">
            
            <div class="flex flex-col items-center mb-8">
                <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-400 mb-4 border border-blue-500/20">
                    <i class="fa-solid fa-key text-xl animate-pulse"></i>
                </div>
                <h2 class="text-white text-2xl font-semibold tracking-tight">
                    Reset Password
                </h2>
                <p class="text-zinc-400 text-sm mt-1 text-center">
                    Enter your email to receive a secure password reset link.
                </p>
            </div>

            <div class="mb-6 relative group">
                <label class="text-xs font-medium text-zinc-400 block mb-2 transition-colors group-focus-within:text-blue-400">
                    Email Address
                </label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-zinc-500 pointer-events-none transition-colors group-focus-within:text-blue-400">
                        <i class="fa-regular fa-envelope"></i>
                    </span>
                    <input
                        type="email"
                        required
                        placeholder="name@company.com"
                        class="w-full pl-10 pr-4 py-3 rounded-xl bg-zinc-800/50 border border-zinc-700/60 text-white placeholder-zinc-500 outline-none transition-all duration-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 focus:bg-zinc-800">
                </div>
            </div>

            <button
                type="submit"
                class="w-full bg-blue-600 hover:bg-blue-500 active:scale-[0.98] text-white font-medium py-3 rounded-xl transition-all duration-200 shadow-lg shadow-blue-600/20 hover:shadow-blue-600/30 flex items-center justify-center gap-2 group">
                <span>Send Reset Link</span>
                <i class="fa-solid fa-arrow-right text-sm transition-transform duration-200 group-hover:translate-x-1"></i>
            </button>

            <div class="mt-6 text-center">
                <a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors duration-200 inline-flex items-center gap-1.5 group">
                    <i class="fa-solid fa-arrow-left text-xs transition-transform duration-200 group-hover:-translate-x-0.5"></i>
                    Back to log in
                </a>
            </div>

        </form>
    </div>

</body>
</html>