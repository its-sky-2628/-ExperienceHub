<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExperienceHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<footer class="text-center text-zinc-500 py-6 border-t border-zinc-800">
     ExperienceHub 2026 • Crafted by
    <span class="text-blue-400 font-semibold">
        Shreyansh Yadav
    </span>
</footer>
<body class="bg-zinc-950 text-white">

<nav class="flex justify-between items-center flex-wrap gap-4 mb-10">

    <h1 class="text-3xl font-bold text-white">
        ⚡️ ExperienceHub
    </h1>

    <div class="flex gap-3 flex-wrap">
        <a href="/feed"
           class="bg-green-500 hover:bg-green-600 text-white px-5 py-2 rounded-xl font-medium transition">
            Explore Posts
        </a>

        <a href="/logout"
           class="bg-red-500 hover:bg-red-600 text-white px-5 py-2 rounded-xl font-medium transition">
            Logout
        </a>
    </div>

</nav>      

        <!-- Top Section -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-10">

            <!-- Profile Card -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">

                <div class="flex flex-col items-center">

<div class="flex flex-col items-center">

        <% if(user.profilePic){ %>

        <img
    src="<%= user.profilePic %>"
    alt="Profile"
        class="w-24 h-24 rounded-full object-cover border-4 border-blue-500 shadow-lg">

        <% } else { %>

        <div class="w-24 h-24 rounded-full bg-blue-600 flex items-center justify-center text-4xl font-bold">
            <%= user.name.charAt(0).toUpperCase() %>
        </div>

    <% } %>

    <h2 class="text-xl font-bold mt-4">
        <%= user.name %>
    </h2>

    <p class="text-zinc-400">
        @<%= user.username %>
    </p>

    <!-- Upload Profile Photo -->
    <form
        action="/upload-profile"
        method="post"
        enctype="multipart/form-data"
        class="mt-4 w-full">

        <input
            type="file"
            name="profilePic"
            accept="image/*"
            class="w-full text-sm text-zinc-300 mb-2">

        <button
            type="submit"
            class="w-full bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg font-medium transition">

            📸 Upload Profile Photo

        </button>

    </form>

</div>
                    <h2 class="text-xl font-bold mt-4">
                        <%= user.name %>
                    </h2>

                    <p class="text-zinc-400">
                        @<%= user.username %>
                    </p>

                </div>

                <div class="mt-6 bg-zinc-950 rounded-xl p-4 text-center">

                    <h3 class="text-2xl font-bold">
                        <%= user.posts.length %>
                    </h3>

                    <p class="text-zinc-500">
                        Total Posts
                    </p>

                </div>

            </div>

            <!-- Share Experience -->
            <div class="lg:col-span-3 bg-zinc-900 border border-zinc-800 rounded-2xl p-6">

                <h3 class="text-xl font-semibold mb-4">
                    ✍️ Share Your Experience
                </h3>

                <form action="/post" method="post">
                    <label class="block text-zinc-300 font-medium mb-2">
                        📂 Choose a category for your post
                    </label>
                    <select
                        name="category"
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-3 mb-3 text-white">

                        <option value="">Select Category ✨</option>
                        <option>🌱 Life Experience</option>
                        <option>❤️ Shayari & Poetry</option>
                        <option>💕 Love Stories</option>
                        <option>🤫 Secrets & Confessions</option>
                        <option>🎓 College Life</option>
                        <option>💻 Coding & Tech</option>
                        <option>🎮 Gaming</option>
                        <option>✈️ Travel & Adventure</option>
                        <option>💪 Fitness & Health</option>

                    </select>
     

                    <textarea
                        name="content"
                        id="content"
                        placeholder="What's on your mind today?"
                        class="w-full h-40 bg-zinc-950 border border-zinc-800 rounded-xl p-4 resize-none focus:outline-none focus:border-blue-500"></textarea>

                    <button
                        class="mt-4 bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-xl font-semibold transition">

                        Create Post

                    </button>

                </form>

            </div>

        </div>

        <!-- Posts Heading -->
        <h2 class="text-3xl font-bold mb-6">
            Your Posts
        </h2>

        <!-- Posts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            <% user.posts.reverse().forEach(function(post){ %>

            <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-5 hover:border-zinc-700 transition shadow-lg">

                <div class="flex justify-between items-center mb-3">

                    <h4 class="text-blue-400 font-semibold">
                        @<%= user.username %>
                    </h4>
                    <p class="text-yellow-400 text-sm mb-2">
                        <%= post.category %>
                    </p>

                    <span class="text-zinc-400 text-sm">
                        ❤️ <%= post.likes.length %>
                    </span>

                </div>

                <p class="text-zinc-200 leading-relaxed max-h-24 overflow-hidden">
                    <%= post.content %>
                </p>

                <!-- Actions -->
                <div class="flex gap-4 mt-4">

                    <a
                        href="/like/<%= post._id %>"
                        class="text-red-400 hover:text-red-300 text-sm font-medium">

                        <%= post.likes.indexOf(user._id) === -1 ? "❤️ Like" : "💔 Unlike" %>

                    </a>

                    <a
                        href="/edit/<%= post._id %>"
                        class="text-yellow-400 hover:text-yellow-300 text-sm font-medium">

                        ✏️ Edit

                    </a>

                    <a
                        href="/delete/<%= post._id %>"
                        class="text-red-500 hover:text-red-400 text-sm font-medium">

                        🗑️ Delete

                    </a>

                </div>

                <!-- Comment Form -->
                <form action="/comment/<%= post._id %>" method="post" class="mt-4">

                    <input
                        type="text"
                        name="comment"
                        placeholder="Write a comment..."
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-2 text-sm text-white">

                    <button
                        type="submit"
                        class="mt-2 bg-green-600 hover:bg-green-700 px-3 py-2 rounded-lg text-sm">

                        Comment

                    </button>

                </form>

                <!-- Comments -->
                <% if(post.comments.length > 0){ %>

                <div class="mt-4 border-t border-zinc-800 pt-3">

                    <% post.comments.forEach(function(comment){ %>

                    <div class="bg-zinc-950 rounded-lg p-2 mb-2">

                        <p class="text-xs text-zinc-300">
                            💬 <%= comment.text %>
                        </p>

                    </div>

                    <% }) %>

                </div>

                <% } %>

            </div>

            <% }) %>

        </div>

    </div>

</body>
</html> 