<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= post.user.username %> | ExperienceHub</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-zinc-950 text-white">


<div class="max-w-5xl mx-auto py-14 px-6">


<a
href="/"
class="text-blue-400 hover:text-blue-300">

← Back Home

</a>



<div class="bg-zinc-900 border border-zinc-800 rounded-3xl mt-8 overflow-hidden shadow-2xl">


<% if(post.image){ %>

<img
src="<%= post.image %>"
class="w-full h-[450px] object-cover">

<% } %>


<div class="p-10">


<div class="flex items-center gap-4 mb-8">

<% if(post.user.profilePic){ %>

<img
src="<%= post.user.profilePic %>"
class="w-16 h-16 rounded-full object-cover border-2 border-blue-500">

<% }else{ %>

<div class="w-16 h-16 rounded-full bg-blue-600 flex justify-center items-center font-bold text-2xl">

<%= post.user.username.charAt(0).toUpperCase() %>

</div>

<% } %>


<div>

<h2 class="text-2xl font-bold">

@<%= post.user.username %>

</h2>

<p class="text-zinc-500">

<%= post.category %>

</p>

</div>

</div>



<p class="text-xl leading-10 text-zinc-300 whitespace-pre-line">

<%= post.content %>

</p>



<div class="flex gap-10 mt-10 text-lg">

<p class="text-red-400">

❤️ <%= post.likes.length %> Likes

</p>

</div>


</div>

</div>

</div>

</body>
</html>