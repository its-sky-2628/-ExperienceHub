<!DOCTYPE html>

<html>

<head>

<title>Reset Password</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-zinc-950 flex justify-center items-center min-h-screen">

<form

action="/reset/<%= token %>"

method="POST"

class="bg-zinc-900 p-8 rounded-3xl w-96">

<h1 class="text-white text-3xl mb-6">

Create New Password

</h1>

<input

type="password"

name="password"

placeholder="New Password"

required

class="w-full p-3 bg-zinc-800 rounded-xl text-white mb-6">

<button

class="w-full bg-green-600 p-3 rounded-xl text-white">

Update Password

</button>

</form>

</body>

</html>