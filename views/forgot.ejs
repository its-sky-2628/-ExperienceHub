<!DOCTYPE html>
<html>
<head>

<title>Forgot Password</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-zinc-950 flex justify-center items-center min-h-screen">

<form
action="/forgot"
method="POST"
class="bg-zinc-900 p-8 rounded-3xl w-96">

<h1 class="text-white text-3xl mb-6 font-bold">

Forgot Password

</h1>

<input

type="email"

name="email"

placeholder="Enter your email"

required

class="w-full p-3 rounded-xl bg-zinc-800 text-white mb-6">

<button

class="w-full bg-blue-600 p-3 rounded-xl text-white">

Send Reset Link

</button>

</form>

</body>

</html>