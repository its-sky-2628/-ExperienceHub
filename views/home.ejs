<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExperienceHub</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        html{
            scroll-behavior:smooth;
        }

        body{
            background:#09090B;
            overflow-x:hidden; /* एक्स्ट्रा विड्थ को रोकने के लिए */
        }

        .hero-glow{
            position:absolute;
            width:300px; /* मोबाइल के लिए छोटा ग्लो */
            height:300px;
            background:#2563eb;
            filter:blur(120px);
            opacity:.15;
            border-radius:999px;
            z-index:0;
        }

        @media (min-width: 768px) {
            .hero-glow {
                width: 450px;
                height: 450px;
                filter: blur(170px);
                opacity: .18;
            }
        }

        .hero-glow2{
            position:absolute;
            width:280px;
            height:280px;
            background:#7c3aed;
            filter:blur(120px);
            opacity:.12;
            border-radius:999px;
            z-index:0;
            right:0;
            bottom:-100px;
        }

        @media (min-width: 768px) {
            .hero-glow2 {
                width: 420px;
                height: 420px;
                filter: blur(170px);
                opacity: .15;
            }
        }
    </style>
</head>

<body class="text-white">

    <!-- Background Glow -->
    <div class="hero-glow -top-24 -left-24"></div>
    <div class="hero-glow2"></div>

    <!-- ================= NAVBAR ================= -->
    <!-- ✅ मोबाइल पर पैडिंग px-4 और डेस्कटॉप पर px-8 की गई है -->
    <nav class="max-w-7xl mx-auto flex justify-between items-center px-4 sm:px-8 py-5 sm:py-7 relative z-10">
        <!-- मोबाइल पर लोगो साइज़ छोटा (text-xl) और डेस्कटॉप पर text-3xl -->
        <h1 class="text-xl sm:text-2xl md:text-3xl font-bold tracking-wide">⚡ ExperienceHub</h1>
        
        <div class="hidden md:flex items-center gap-8 text-zinc-400 font-medium">
            <a href="/feed" class="hover:text-white transition">Stories</a>
            <a href="#why" class="hover:text-white transition">Why Us</a>
        </div>

        <!-- मोबाइल पर बटन्स का साइज़ और पैडिंग एडजस्ट की है -->
        <div class="flex items-center gap-3 sm:gap-4">
            <a href="/login" class="text-sm sm:text-base text-zinc-300 hover:text-white transition">Login</a>
            <a href="/register" class="bg-blue-600 hover:bg-blue-700 px-4 py-2.5 sm:px-6 sm:py-3 rounded-xl text-sm sm:text-semibold font-semibold transition">Get Started</a>
        </div>
    </nav>

    <!-- ================= HERO ================= -->
    <!-- ✅ मोबाइल पर pt-20 pb-24 ताकि हेडर बहुत नीचे न भागे -->
    <section class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 md:pt-32 pb-24 md:pb-40 text-center">
        <!-- ✅ सबसे ज़रूरी फिक्स: हेडिंग साइज़ मोबाइल के लिए text-4xl/text-5xl और बड़ी स्क्रीन के लिए 8xl किया -->
        <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-extrabold bg-gradient-to-r from-blue-400 via-cyan-400 to-purple-500 bg-clip-text text-transparent leading-tight tracking-tight">
            ⚡ ExperienceHub
        </h1>
        <h2 class="mt-4 sm:mt-6 text-lg sm:text-xl md:text-3xl font-semibold text-blue-400">Real People. Raw Stories. Real Impact.</h2>
        <p class="mt-4 italic text-zinc-300 text-sm sm:text-lg">"Your story today is someone's inspiration tomorrow."</p>
        <p class="max-w-3xl mx-auto mt-6 text-zinc-400 text-sm sm:text-base md:text-xl leading-relaxed sm:leading-9">
            Discover authentic experiences shared by real people.
            Learn from others, share your own journey, and inspire millions through your story.
        </p>

        <a
        href="/register"
        class="inline-flex items-center gap-3 mt-10 bg-gradient-to-r from-blue-600 via-cyan-500 to-purple-600 hover:scale-105 transition duration-300 px-6 py-3.5 sm:px-8 sm:py-4 rounded-2xl text-base sm:text-lg font-semibold shadow-2xl">
        📖 Explore Stories
         </a>

        <!-- Small Community Numbers - गैप और टेक्स्ट साइज़ रिस्पॉन्सिव किया गया -->
        <div class="mt-16 md:mt-24 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
            <div>
                <h2 class="text-2xl sm:text-4xl font-bold text-blue-400">1200+</h2>
                <p class="text-zinc-500 text-xs sm:text-sm mt-1 sm:mt-2">Experiences</p>
            </div>
            <div>
                <h2 class="text-2xl sm:text-4xl font-bold text-purple-400">500+</h2>
                <p class="text-zinc-500 text-xs sm:text-sm mt-1 sm:mt-2">Members</p>
            </div>
            <div>
                <h2 class="text-2xl sm:text-4xl font-bold text-pink-400">20K+</h2>
                <p class="text-zinc-500 text-xs sm:text-sm mt-1 sm:mt-2">Likes</p>
            </div>
            <div>
                <h2 class="text-2xl sm:text-4xl font-bold text-green-400">10K+</h2>
                <p class="text-zinc-500 text-xs sm:text-sm mt-1 sm:mt-2">Stories Read</p>
            </div>
        </div>
    </section>

    <!-- Divider -->
    <div class="w-24 sm:w-32 h-1 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto rounded-full my-12 sm:my-20"></div>

    <!-- ================= STORIES SECTION (CONTAINER) ================= -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-12">
        
        <h2 class="text-2xl sm:text-4xl font-bold text-center mb-10 sm:mb-14">📖 Stories From Our Community</h2>

        <!-- ================= LATEST STORIES ================= -->
        <div class="mt-4">
            <h2 class="text-2xl sm:text-3xl font-bold mb-6 sm:mb-8 flex items-center gap-2 sm:gap-3">🆕 Latest Stories</h2>
            <!-- md:grid-cols-3 और मोबाइल पर ऑटोमैटिक 1 कॉलम -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
                <% latestPosts.forEach(function(post){ %>
                <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-5 sm:p-6 hover:border-blue-500 hover:-translate-y-2 transition duration-300 shadow-xl">
                    <div class="flex items-center gap-3 mb-4">
                        <% if(post.user.profilePic){ %>
                            <img src="<%= post.user.profilePic %>" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full object-cover border border-zinc-700">
                        <% } else { %>
                            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-blue-600 flex items-center justify-center font-bold text-sm sm:text-base">
                                <%= post.user.username.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div>
                            <h3 class="font-semibold text-sm sm:text-base">@<%= post.user.username %></h3>
                            <p class="text-[10px] sm:text-xs text-zinc-500"><%= post.category %></p>
                        </div>
                    </div>

                    <% if(post.image){ %>
                    <img src="<%= post.image %>" class="w-full h-40 sm:h-48 object-cover rounded-2xl mb-4">
                    <% } %>

                    <p class="text-zinc-300 text-sm sm:text-base leading-relaxed sm:leading-7"><%= post.content.substring(0,120) %>...</p>

                    <div class="flex justify-between items-center mt-6">
                        <div class="flex items-center gap-2 sm:gap-3 text-xs sm:text-sm">
                            <span class="text-red-400">❤️ <%= post.likes.length %></span>
                            <span class="text-zinc-500"><%= post.comments.length %> Comments</span>
                        </div>
                        <a href="/story/<%= post._id %>" class="text-blue-400 hover:text-blue-300 font-semibold text-xs sm:text-sm">Read Story →</a>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>

        <!-- Divider -->
        <div class="w-24 sm:w-32 h-1 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto rounded-full my-12 sm:my-20"></div>

        <!-- ================= MOST LOVED STORIES ================= -->
        <div class="mt-12 sm:mt-24">
            <h2 class="text-2xl sm:text-3xl font-bold mb-6 sm:mb-8 flex items-center gap-2 sm:gap-3">❤️ Most Loved Stories</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
                <% lovedPosts.forEach(function(post){ %>
                <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-5 sm:p-6 hover:border-pink-500 hover:-translate-y-2 transition duration-300 shadow-xl">
                    <div class="flex items-center gap-3 mb-4">
                        <% if(post.user.profilePic){ %>
                            <img src="<%= post.user.profilePic %>" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full object-cover border border-zinc-700">
                        <% } else { %>
                            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-pink-600 flex items-center justify-center font-bold text-sm sm:text-base">
                                <%= post.user.username.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div>
                            <h3 class="font-semibold text-sm sm:text-base">@<%= post.user.username %></h3>
                            <p class="text-[10px] sm:text-xs text-zinc-500"><%= post.category %></p>
                        </div>
                    </div>

                    <% if(post.image){ %>
                    <img src="<%= post.image %>" class="w-full h-40 sm:h-48 object-cover rounded-2xl mb-4">
                    <% } %>

                    <p class="text-zinc-300 text-sm sm:text-base leading-relaxed sm:leading-7"><%= post.content.substring(0,120) %>...</p>

                    <div class="flex justify-between items-center mt-6">
                        <div class="flex items-center gap-2 sm:gap-3 text-xs sm:text-sm">
                            <span class="text-red-400">❤️ <%= post.likes.length %></span>
                            <span class="text-zinc-500"><%= post.comments.length %> Comments</span>
                        </div>
                        <a href="/story/<%= post._id %>" class="text-pink-400 hover:text-pink-300 font-semibold text-xs sm:text-sm">Read Story →</a>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>

    </section>

    <!-- ================= WHY EXPERIENCEHUB ================= -->
    <section id="why" class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-24">
        <h2 class="text-2xl sm:text-4xl font-bold text-center mb-4 sm:mb-5">❤️ Why Choose ExperienceHub?</h2>
        <p class="text-zinc-400 text-center max-w-2xl mx-auto mb-10 sm:mb-16 text-sm sm:text-base">
            ExperienceHub isn't just another social platform.
            It's a place where real people share real experiences
            to inspire, guide and help others.
        </p>

        <!-- मोबाइल पर 1 कॉलम, टैबलेट पर 2, और डेस्कटॉप पर 4 कॉलम्स -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
            <!-- Card 1 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 sm:p-8 text-center hover:border-blue-500 hover:-translate-y-2 transition duration-300">
                <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">📝</div>
                <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Share Stories</h3>
                <p class="text-zinc-400 text-sm sm:text-base leading-relaxed sm:leading-7">Share your real-life experiences and let your journey inspire thousands of people.</p>
            </div>

            <!-- Card 2 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 sm:p-8 text-center hover:border-purple-500 hover:-translate-y-2 transition duration-300">
                <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">📚</div>
                <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Learn From Others</h3>
                <p class="text-zinc-400 text-sm sm:text-base leading-relaxed sm:leading-7">Read authentic experiences and avoid mistakes others have already faced.</p>
            </div>

            <!-- Card 3 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 sm:p-8 text-center hover:border-pink-500 hover:-translate-y-2 transition duration-300">
                <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">🤝</div>
                <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Build Community</h3>
                <p class="text-zinc-400 text-sm sm:text-base leading-relaxed sm:leading-7">Connect with people through meaningful stories instead of meaningless posts.</p>
            </div>

            <!-- Card 4 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 sm:p-8 text-center hover:border-green-500 hover:-translate-y-2 transition duration-300">
                <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">🚀</div>
                <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Inspire Others</h3>
                <p class="text-zinc-400 text-sm sm:text-base leading-relaxed sm:leading-7">Every experience can change someone's life. Your story could be the next inspiration.</p>
            </div>
        </div>
    </section>

    <!-- ================= FOOTER ================= -->
    <footer class="border-t border-zinc-800 mt-12 sm:mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
            <div class="text-center">
                <h2 class="text-3xl sm:text-4xl font-bold mb-3 sm:mb-4">⚡ ExperienceHub</h2>
                <p class="text-zinc-400 text-sm sm:text-lg">Real People. Raw Stories. Real Impact.</p>
                <p class="italic text-zinc-500 mt-3 sm:mt-4 text-xs sm:text-sm">"Your story today is someone's inspiration tomorrow."</p>
                <p class="text-zinc-500 text-xs mt-3">Made in 🇮🇳 for storytellers around the world.</p>
            </div>

            <!-- लिंक्स मोबाइल पर भी सुंदर तरीके से रैप होंगे -->
            <div class="flex flex-wrap justify-center gap-4 sm:gap-8 mt-8 sm:mt-12 text-zinc-400 text-sm sm:text-base">
                <a href="/" class="hover:text-white transition">Home</a>
                <a href="/feed" class="hover:text-white transition">Explore</a>
                <a href="/login" class="hover:text-white transition">Login</a>
                <a href="/register" class="hover:text-white transition">Register</a>
            </div>

            <div class="mt-8 sm:mt-12 text-center text-zinc-600 text-xs sm:text-sm">
                © 2026 ExperienceHub • Crafted with ❤️ by Shreyansh Yadav
            </div>
        </div>
    </footer>

</body>
</html>