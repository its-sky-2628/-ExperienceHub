<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExperienceHub</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        html{
            scroll-behavior:smooth;
        }

        body{
            background:#09090B;
            overflow-x:hidden;
        }

        .hero-glow{
            position:absolute;
            width:450px;
            height:450px;
            background:#2563eb;
            filter:blur(170px);
            opacity:.18;
            border-radius:999px;
            z-index:0;
        }

        .hero-glow2{
            position:absolute;
            width:420px;
            height:420px;
            background:#7c3aed;
            filter:blur(170px);
            opacity:.15;
            border-radius:999px;
            z-index:0;
            right:0;
            bottom:-100px;
        }
    </style>
</head>

<body class="text-white">

    <!-- Background Glow -->
    <div class="hero-glow -top-24 -left-24"></div>
    <div class="hero-glow2"></div>

    <!-- ================= NAVBAR ================= -->
    <!-- ✅ Fix 4: Added Center Navigation Links (Stories & Why Us) -->
    <nav class="max-w-7xl mx-auto flex justify-between items-center px-8 py-7 relative z-10">
        <h1 class="text-3xl font-bold tracking-wide">⚡ ExperienceHub</h1>
        
        <div class="hidden md:flex items-center gap-8 text-zinc-400 font-medium">
            <a href="/feed" class="hover:text-white transition">Stories</a>
            <a href="#why" class="hover:text-white transition">Why Us</a>
        </div>

        <div class="flex items-center gap-4">
            <a href="/login" class="text-zinc-300 hover:text-white transition">Login</a>
            <a href="/register" class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-xl font-semibold transition">Get Started</a>
        </div>
    </nav>

    <!-- ================= HERO ================= -->
    <!-- ✅ Fix 1: Hero size increased to pt-32 pb-40 -->
    <section class="relative z-10 max-w-6xl mx-auto px-6 pt-32 pb-40 text-center">
        <!-- ✅ Fix 2 & 3: Hero heading text size increased with premium gradient text effect -->
        <h1 class="text-7xl md:text-8xl font-extrabold bg-gradient-to-r from-blue-400 via-cyan-400 to-purple-500 bg-clip-text text-transparent leading-tight tracking-tight">
            ⚡ ExperienceHub
        </h1>
        <h2 class="mt-6 text-2xl md:text-3xl font-semibold text-blue-400">Real People. Raw Stories. Real Impact.</h2>
        <p class="mt-5 italic text-zinc-300 text-lg">"Your story today is someone's inspiration tomorrow."</p>
        <p class="max-w-3xl mx-auto mt-8 text-zinc-400 text-xl leading-9">
            Discover authentic experiences shared by real people.
            Learn from others, share your own journey, and inspire millions through your story.
        </p>

        <a
        href="/register"
        class="inline-flex items-center gap-3 mt-12 bg-gradient-to-r from-blue-600 via-cyan-500 to-purple-600 hover:scale-105 transition duration-300 px-8 py-4 rounded-2xl text-lg font-semibold shadow-2xl">
        📖 Explore Stories
         </a>

        <!-- Small Community Numbers -->
        <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8">
            <div>
                <h2 class="text-4xl font-bold text-blue-400">1200+</h2>
                <p class="text-zinc-500 mt-2">Experiences</p>
            </div>
            <div>
                <h2 class="text-4xl font-bold text-purple-400">500+</h2>
                <p class="text-zinc-500 mt-2">Members</p>
            </div>
            <div>
                <h2 class="text-4xl font-bold text-pink-400">20K+</h2>
                <p class="text-zinc-500 mt-2">Likes</p>
            </div>
            <div>
                <h2 class="text-4xl font-bold text-green-400">10K+</h2>
                <p class="text-zinc-500 mt-2">Stories Read</p>
            </div>
        </div>
    </section>

    <!-- ✅ Fix (Important Change 1): Hero aur Stories ke beech dynamic divider -->
    <div class="w-32 h-1 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto rounded-full my-20"></div>

    <!-- ================= STORIES SECTION (CONTAINER) ================= -->
    <section class="max-w-7xl mx-auto px-6 py-12">
        
        <h2 class="text-4xl font-bold text-center mb-14">📖 Stories From Our Community</h2>

        <!-- ================= LATEST STORIES ================= -->
        <div class="mt-8">
            <h2 class="text-3xl font-bold mb-8 flex items-center gap-3">🆕 Latest Stories</h2>
            <div class="grid md:grid-cols-3 gap-8">
                <% latestPosts.forEach(function(post){ %>
                <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 hover:border-blue-500 hover:-translate-y-2 transition duration-300 shadow-xl">
                    <div class="flex items-center gap-3 mb-4">
                        <% if(post.user.profilePic){ %>
                            <img src="<%= post.user.profilePic %>" class="w-12 h-12 rounded-full object-cover border border-zinc-700">
                        <% } else { %>
                            <div class="w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center font-bold">
                                <%= post.user.username.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div>
                            <h3 class="font-semibold">@<%= post.user.username %></h3>
                            <p class="text-xs text-zinc-500"><%= post.category %></p>
                        </div>
                    </div>

                    <% if(post.image){ %>
                    <img src="<%= post.image %>" class="w-full h-48 object-cover rounded-2xl mb-4">
                    <% } %>

                    <p class="text-zinc-300 leading-7"><%= post.content.substring(0,120) %>...</p>

                    <div class="flex justify-between items-center mt-6">
                        <!-- ✅ Fix 5: Appended Comments Array size inside stats footer -->
                        <div class="flex items-center gap-3">
                            <span class="text-red-400">❤️ <%= post.likes.length %></span>
                            <span class="text-zinc-500 text-sm">💬 <%= post.comments.length %> Comments</span>
                        </div>
                        <!-- ✅ Fix 6: Custom Premium CTA referencing specific detailed paths -->
                        <a href="/story/<%= post._id %>" class="text-blue-400 hover:text-blue-300 font-semibold text-sm">📖 Read Story →</a>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>

        <!-- ✅ Fix (Important Change 2): Latest aur Most Loved ke beech premium spacing divider -->
        <div class="w-32 h-1 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto rounded-full my-20"></div>

        <!-- ================= MOST LOVED STORIES ================= -->
        <div class="mt-24">
            <h2 class="text-3xl font-bold mb-8 flex items-center gap-3">❤️ Most Loved Stories</h2>
            <div class="grid md:grid-cols-3 gap-8">
                <% lovedPosts.forEach(function(post){ %>
                <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 hover:border-pink-500 hover:-translate-y-2 transition duration-300 shadow-xl">
                    <div class="flex items-center gap-3 mb-4">
                        <% if(post.user.profilePic){ %>
                            <img src="<%= post.user.profilePic %>" class="w-12 h-12 rounded-full object-cover border border-zinc-700">
                        <% } else { %>
                            <div class="w-12 h-12 rounded-full bg-pink-600 flex items-center justify-center font-bold">
                                <%= post.user.username.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div>
                            <h3 class="font-semibold">@<%= post.user.username %></h3>
                            <p class="text-xs text-zinc-500"><%= post.category %></p>
                        </div>
                    </div>

                    <% if(post.image){ %>
                    <img src="<%= post.image %>" class="w-full h-48 object-cover rounded-2xl mb-4">
                    <% } %>

                    <p class="text-zinc-300 leading-7"><%= post.content.substring(0,120) %>...</p>

                    <div class="flex justify-between items-center mt-6">
                        <!-- ✅ Fix 5: Appended Comments Array size inside stats footer -->
                        <div class="flex items-center gap-3">
                            <span class="text-red-400">❤️ <%= post.likes.length %></span>
                            <span class="text-zinc-500 text-sm">💬 <%= post.comments.length %> Comments</span>
                        </div>
                        <!-- ✅ Fix 6: Custom Premium CTA referencing specific detailed paths -->
                        <a href="/story/<%= post._id %>" class="text-pink-400 hover:text-pink-300 font-semibold text-sm">📖 Read Story →</a>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>

    </section>

    <!-- ================= WHY EXPERIENCEHUB ================= -->
    <!-- ✅ Fix 7: Section is matched with id="why" for smoother in-page navigation anchors -->
    <section id="why" class="max-w-7xl mx-auto px-6 py-24">
        <h2 class="text-4xl font-bold text-center mb-5">❤️ Why Choose ExperienceHub?</h2>
        <p class="text-zinc-400 text-center max-w-2xl mx-auto mb-16">
            ExperienceHub isn't just another social platform.
            It's a place where real people share real experiences
            to inspire, guide and help others.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Card 1 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 text-center hover:border-blue-500 hover:-translate-y-2 transition duration-300">
                <div class="text-5xl mb-6">📝</div>
                <h3 class="text-2xl font-bold mb-4">Share Stories</h3>
                <p class="text-zinc-400 leading-7">Share your real-life experiences and let your journey inspire thousands of people.</p>
            </div>

            <!-- Card 2 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 text-center hover:border-purple-500 hover:-translate-y-2 transition duration-300">
                <div class="text-5xl mb-6">📚</div>
                <h3 class="text-2xl font-bold mb-4">Learn From Others</h3>
                <p class="text-zinc-400 leading-7">Read authentic experiences and avoid mistakes others have already faced.</p>
            </div>

            <!-- Card 3 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 text-center hover:border-pink-500 hover:-translate-y-2 transition duration-300">
                <div class="text-5xl mb-6">🤝</div>
                <h3 class="text-2xl font-bold mb-4">Build Community</h3>
                <p class="text-zinc-400 leading-7">Connect with people through meaningful stories instead of meaningless posts.</p>
            </div>

            <!-- Card 4 -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 text-center hover:border-green-500 hover:-translate-y-2 transition duration-300">
                <div class="text-5xl mb-6">🚀</div>
                <h3 class="text-2xl font-bold mb-4">Inspire Others</h3>
                <p class="text-zinc-400 leading-7">Every experience can change someone's life. Your story could be the next inspiration.</p>
            </div>
        </div>
    </section>

    <!-- ================= FOOTER ================= -->
    <footer class="border-t border-zinc-800 mt-16">
        <div class="max-w-7xl mx-auto px-6 py-16">
            <div class="text-center">
                <h2 class="text-4xl font-bold mb-4">⚡ ExperienceHub</h2>
                <p class="text-zinc-400 text-lg">Real People. Raw Stories. Real Impact.</p>
                <p class="italic text-zinc-500 mt-4">"Your story today is someone's inspiration tomorrow."</p>
                <!-- ✅ Fix 8: Appended custom geopolitical storytelling tag inside footer info -->
                <p class="text-zinc-500 text-sm mt-3">Made in 🇮🇳 for storytellers around the world.</p>
            </div>

            <div class="flex justify-center gap-8 mt-12 text-zinc-400">
                <a href="/" class="hover:text-white transition">Home</a>
                <a href="/feed" class="hover:text-white transition">Explore</a>
                <a href="/login" class="hover:text-white transition">Login</a>
                <a href="/register" class="hover:text-white transition">Register</a>
            </div>

            <div class="mt-12 text-center text-zinc-600 text-sm">
                © 2026 ExperienceHub • Crafted with ❤️ by Shreyansh Yadav
            </div>
        </div>
    </footer>

</body>
</html>